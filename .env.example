# --- Mode d'exécution ---
# scraper  ou  gmail_fetcher
APP_TARGET=scraper

# snowflake  ou  local
STORAGE_BACKEND=local


# --- Snowflake (backend snowflake uniquement) ---
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/private_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=passphrase
SNOWFLAKE_USER=your_user
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=your_role

SNOWFLAKE_STAGE_ROOT=@SCRAPER_STAGE
SCRAPED_DOCUMENTS_TABLE=SCRAPED_DOCUMENTS
SCRAPER_RUNS_TABLE=SCRAPER_RUNS
SCRAPER_ERRORS_TABLE=SCRAPER_ERRORS


# --- Gmail fetcher ---
GMAIL_USER_ID=me
GMAIL_LABEL_ID=...
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_OUTPUT_DIR=gmail_output

# SMTP error notifications
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM=
SMTP_TO=
SMTP_SUBJECT_PREFIX=[Stonelake]
